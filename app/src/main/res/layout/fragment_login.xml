<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/frameLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".ui.fragment.HomeFragment">

        <ImageView
            android:id="@+id/backgroundloginImg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="bg img"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/login1" />

        <Button
            android:id="@+id/signinGoogle"
            android:layout_width="260dp"
            android:layout_height="50dp"
            android:layout_marginStart="84dp"
            android:text="Continue with google"
            android:textColorLink="#DA1616"
            app:layout_constraintBottom_toBottomOf="@+id/backgroundloginImg"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/backgroundloginImg"
            app:layout_constraintVertical_bias="0.868" />

        <Button
            android:id="@+id/signin"
            android:layout_width="115dp"
            android:layout_height="50dp"
            android:layout_marginStart="88dp"
            android:text="Sign-In"
            app:layout_constraintBottom_toBottomOf="@+id/backgroundloginImg"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/backgroundloginImg"
            app:layout_constraintVertical_bias="0.785" />

        <Button
            android:id="@+id/signup"
            android:layout_width="115dp"
            android:layout_height="50dp"
            android:layout_marginStart="228dp"
            android:text="Sign-Up"
            app:layout_constraintBottom_toBottomOf="@+id/backgroundloginImg"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/backgroundloginImg"
            app:layout_constraintVertical_bias="0.786"
            app:rippleColor="#F1E6E6" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>